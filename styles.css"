/* ========== 全局样式 ========== */
html, body { margin: 0; padding: 0; }

/* 手机外壳样式 */
.phone-frame {
  background: #fff;
}

/* 隐藏滚动条（保留滚动能力） */
#app::-webkit-scrollbar,
.thin-scroll::-webkit-scrollbar { width: 0; height: 0; }

/* Tab 激活状态 */
.tab-btn {
  color: #98A5A1;
  transition: color .25s;
}
.tab-btn.active {
  color: #2E936A;
}

/* 卡片 fade-in 动画 */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(8px); }
  to   { opacity: 1; transform: translateY(0); }
}
.fade-up { animation: fadeUp .35s ease both; }

/* 页面进入动画 */
@keyframes pageIn {
  from { opacity: 0; transform: translateY(6px); }
  to   { opacity: 1; transform: translateY(0); }
}
.page-in { animation: pageIn .28s ease both; }

/* 模态从底部上滑 */
@keyframes slideUp {
  from { transform: translateY(100%); }
  to   { transform: translateY(0); }
}
.slide-up { animation: slideUp .3s ease both; }

/* 分类 chip 滚动 */
.chip-row {
  display: flex;
  gap: .5rem;
  overflow-x: auto;
  padding-bottom: 2px;
}
.chip-row::-webkit-scrollbar { display: none; }

.chip {
  flex-shrink: 0;
  padding: .35rem .85rem;
  border-radius: 999px;
  font-size: 12px;
  background: #F6F1E7;
  color: #3A4B47;
  border: 1px solid transparent;
  transition: all .2s;
  cursor: pointer;
}
.chip.active {
  background: #DFF5EB;
  color: #2E936A;
  border-color: #8AD5B4;
  font-weight: 500;
}

/* 物品卡 */
.item-card {
  background: #fff;
  border-radius: 14px;
  overflow: hidden;
  box-shadow: 0 2px 10px rgba(31,42,40,.06);
  display: flex;
  flex-direction: column;
  transition: transform .2s ease;
}
.item-card:active { transform: scale(.98); }

.item-card .cover {
  width: 100%;
  aspect-ratio: 1 / 1;
  object-fit: cover;
  background: #F6F1E7;
}

/* 徽章 */
.badge {
  display: inline-flex;
  align-items: center;
  padding: 2px 8px;
  border-radius: 999px;
  font-size: 10px;
  line-height: 1.2;
}

/* 按钮 */
.btn-primary {
  background: linear-gradient(135deg, #5BC296 0%, #2E936A 100%);
  color: #fff;
  border-radius: 12px;
  padding: 12px 18px;
  font-size: 14px;
  font-weight: 500;
  box-shadow: 0 4px 14px rgba(46,147,106,.25);
  transition: transform .15s;
  border: none;
}
.btn-primary:active { transform: scale(.97); }
.btn-primary:disabled {
  background: #C4CCC8;
  box-shadow: none;
  color: #fff;
  cursor: not-allowed;
}

.btn-ghost {
  background: #F6F1E7;
  color: #3A4B47;
  border-radius: 12px;
  padding: 10px 14px;
  font-size: 13px;
}

/* 输入框 */
.field {
  background: #F6F1E7;
  border: 1px solid transparent;
  border-radius: 12px;
  padding: 10px 14px;
  font-size: 14px;
  width: 100%;
  outline: none;
  transition: border-color .2s, background .2s;
  color: #1F2A28;
}
.field:focus {
  background: #fff;
  border-color: #8AD5B4;
}

/* 聊天气泡 */
.bubble {
  max-width: 72%;
  padding: 9px 12px;
  border-radius: 14px;
  font-size: 13px;
  line-height: 1.5;
  word-break: break-word;
  white-space: pre-wrap;
}
.bubble.me {
  background: linear-gradient(135deg,#5BC296,#2E936A);
  color: #fff;
  border-bottom-right-radius: 4px;
}
.bubble.other {
  background: #fff;
  color: #1F2A28;
  border-bottom-left-radius: 4px;
  box-shadow: 0 1px 4px rgba(0,0,0,.05);
}

/* 微小图片 thumb */
.thumb {
  width: 44px;
  height: 44px;
  border-radius: 8px;
  object-fit: cover;
  background: #F6F1E7;
}

/* 发布-上传框 */
.upload-slot {
  width: 72px;
  height: 72px;
  border-radius: 10px;
  background: #F6F1E7;
  border: 1px dashed #B8E7D2;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8AD5B4;
  cursor: pointer;
  position: relative;
  overflow: hidden;
}
.upload-slot img {
  width: 100%; height: 100%; object-fit: cover;
}
.upload-slot .remove {
  position: absolute;
  top: 2px; right: 2px;
  width: 18px; height: 18px;
  background: rgba(0,0,0,.55);
  color: #fff;
  border-radius: 999px;
  font-size: 11px;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer;
}

/* 列表分割 */
.list-item {
  display: flex;
  align-items: center;
  padding: 12px 14px;
  background: #fff;
  gap: 10px;
}
.list-item + .list-item {
  border-top: 1px solid #F3EFE6;
}

/* 状态小标签 */
.tag-pending { background:#FFF4E0; color:#B9822A; }
.tag-live { background:#DFF5EB; color:#2E936A; }
.tag-done { background:#ECEEF0; color:#6B7B77; }

/* 抽屉/详情遮罩 */
.mask {
  position: absolute;
  inset: 0;
  background: rgba(15, 24, 22, .45);
  z-index: 10;
}
