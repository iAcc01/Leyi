// pages/me.js —— 个人中心页
import { ME, MY_ITEMS, MY_WANTS, HISTORY, ITEMS } from '../data.js';
import { timeAgo, esc, toast, openModal, closeModal } from '../utils.js';

export function renderMe(container) {
  const liveCount = MY_ITEMS.filter(i=>i.status==='live').length;
  const pendingCount = MY_ITEMS.filter(i=>i.status==='pending').length;
  const doneCount = MY_ITEMS.filter(i=>i.status==='done').length;

  container.innerHTML = `
    <div class="page-in pb-4">
      <!-- 顶部个人信息 -->
      <div class="relative pb-6">
        <div class="absolute inset-x-0 top-0 h-32 bg-gradient-to-b from-mint-300 to-mint-50"></div>
        <div class="relative px-4 pt-5 flex items-center gap-3">
          <div class="relative">
            <img src="${ME.avatar}" class="w-16 h-16 rounded-2xl bg-white shadow-soft border-2 border-white" />
            <button id="edit-avatar" class="absolute -bottom-1 -right-1 w-6 h-6 rounded-full bg-white shadow flex items-center justify-center">
              <i class="ri-pencil-line text-xs text-ink-500"></i>
            </button>
          </div>
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-1.5">
              <span class="text-base font-semibold">${esc(ME.name)}</span>
              <span class="badge bg-white/80 text-mint-700 text-[10px]"><i class="ri-wechat-line mr-0.5"></i>已授权</span>
            </div>
            <div class="text-[12px] text-ink-700/80 mt-0.5 truncate">${esc(ME.bio)}</div>
          </div>
          <button id="edit-profile" class="text-xs text-ink-500 bg-white/70 backdrop-blur rounded-full px-3 py-1"><i class="ri-edit-line mr-0.5"></i>编辑</button>
        </div>

        <!-- 数据概览 -->
        <div class="relative mx-4 mt-4 grid grid-cols-3 rounded-2xl bg-white shadow-card overflow-hidden">
          <div class="py-3 text-center">
            <div class="text-lg font-semibold text-mint-600">${MY_ITEMS.length}</div>
            <div class="text-[11px] text-ink-500 mt-0.5">我的发布</div>
          </div>
          <div class="py-3 text-center border-x border-ink-300/30">
            <div class="text-lg font-semibold text-mint-600">${MY_WANTS.length}</div>
            <div class="text-[11px] text-ink-500 mt-0.5">我想要的</div>
          </div>
          <div class="py-3 text-center">
            <div class="text-lg font-semibold text-mint-600">${HISTORY.length}</div>
            <div class="text-[11px] text-ink-500 mt-0.5">完成交换</div>
          </div>
        </div>
      </div>

      <!-- 我的资产 -->
      <section class="mx-4 bg-white rounded-2xl shadow-card overflow-hidden">
        <div class="flex items-center justify-between px-4 py-3 border-b border-ink-300/20">
          <div class="text-sm font-semibold">我的发布</div>
          <button id="view-all-pub" class="text-[11px] text-ink-500">全部 ${MY_ITEMS.length} ·
            <span class="text-mint-600">在架 ${liveCount}</span> ·
            <span class="text-amber-600">审核 ${pendingCount}</span> ·
            <span class="text-ink-400">已换 ${doneCount}</span>
          </button>
        </div>
        <div id="pub-list">
          ${MY_ITEMS.slice(0,3).map(pubRow).join('')}
        </div>
      </section>

      <section class="mx-4 mt-3 bg-white rounded-2xl shadow-card overflow-hidden">
        <div class="flex items-center justify-between px-4 py-3 border-b border-ink-300/20">
          <div class="text-sm font-semibold">我想要的</div>
          <span class="text-[11px] text-ink-500">${MY_WANTS.length} 件</span>
        </div>
        <div>
          ${MY_WANTS.map(id => {
            const it = ITEMS.find(i=>i.id===id);
            if (!it) return '';
            return wantRow(it);
          }).join('') || '<div class="p-5 text-center text-xs text-ink-500">在广场点「想要」，即可加入这里</div>'}
        </div>
      </section>

      <section class="mx-4 mt-3 bg-white rounded-2xl shadow-card overflow-hidden">
        <div class="px-4 py-3 border-b border-ink-300/20 text-sm font-semibold">交换记录</div>
        <div>
          ${HISTORY.map(h => `
            <div class="list-item">
              <div class="w-9 h-9 rounded-full bg-mint-100 flex items-center justify-center text-mint-600">
                <i class="ri-loop-left-line"></i>
              </div>
              <div class="flex-1 min-w-0">
                <div class="text-sm truncate">${esc(h.title)}</div>
                <div class="text-[11px] text-ink-400 mt-0.5">${timeAgo(h.time)}</div>
              </div>
              <i class="ri-arrow-right-s-line text-ink-400"></i>
            </div>
          `).join('') || '<div class="p-5 text-center text-xs text-ink-500">尚无记录</div>'}
        </div>
      </section>

      <!-- 辅助功能 -->
      <section class="mx-4 mt-3 bg-white rounded-2xl shadow-card overflow-hidden">
        <div class="list-item" data-act="help">
          <i class="ri-question-line text-mint-600"></i>
          <span class="flex-1 text-sm">帮助中心</span>
          <i class="ri-arrow-right-s-line text-ink-400"></i>
        </div>
        <div class="list-item" data-act="feedback">
          <i class="ri-feedback-line text-mint-600"></i>
          <span class="flex-1 text-sm">反馈与建议</span>
          <i class="ri-arrow-right-s-line text-ink-400"></i>
        </div>
        <div class="list-item" data-act="about">
          <i class="ri-information-line text-mint-600"></i>
          <span class="flex-1 text-sm">关于换换</span>
          <span class="text-[11px] text-ink-400">v1.0.0</span>
          <i class="ri-arrow-right-s-line text-ink-400 ml-1"></i>
        </div>
      </section>

      <div class="text-center text-[11px] text-ink-400 mt-5">—— 简单发布 · 快速匹配 · 信任优先 ——</div>
    </div>
  `;

  // 事件
  container.querySelectorAll('[data-act]').forEach(el => {
    el.addEventListener('click', () => {
      const a = el.dataset.act;
      if (a === 'help') openHelp();
      else if (a === 'feedback') openFeedback();
      else if (a === 'about') openAbout();
    });
  });
  container.querySelectorAll('[data-pub]').forEach(el => {
    el.addEventListener('click', () => toast('物品管理入口（模拟）'));
  });
  container.querySelectorAll('[data-want-card]').forEach(el => {
    el.addEventListener('click', () => toast('查看对方物品详情'));
  });
  container.querySelector('#edit-profile').addEventListener('click', openEditProfile);
  container.querySelector('#edit-avatar').addEventListener('click', () => toast('通过微信授权同步头像（模拟）'));
  container.querySelector('#view-all-pub').addEventListener('click', () => toast('查看全部发布（模拟）'));
}

function pubRow(it) {
  const tag = {
    live: '<span class="badge tag-live">已发布</span>',
    pending: '<span class="badge tag-pending">审核中</span>',
    done: '<span class="badge tag-done">已交换</span>',
  }[it.status];
  return `
    <div class="list-item" data-pub="${it.id}">
      <img src="${it.cover}" class="thumb" />
      <div class="flex-1 min-w-0">
        <div class="text-sm truncate">${esc(it.title)}</div>
        <div class="text-[11px] text-mint-600 truncate mt-0.5">想换 ${esc(it.want)}</div>
      </div>
      <div class="flex flex-col items-end gap-1">
        ${tag}
        <span class="text-[11px] text-ink-400">${timeAgo(it.time)}</span>
      </div>
    </div>
  `;
}

function wantRow(it) {
  return `
    <div class="list-item" data-want-card="${it.id}">
      <img src="${it.cover}" class="thumb" />
      <div class="flex-1 min-w-0">
        <div class="text-sm truncate">${esc(it.title)}</div>
        <div class="text-[11px] text-ink-500 truncate mt-0.5">
          <img src="${it.owner.avatar}" class="inline w-3 h-3 rounded-full mr-1 align-middle" />${esc(it.owner.name)} · ${esc(it.city)}
        </div>
      </div>
      <button class="text-[11px] px-2 py-1 rounded-full bg-mint-100 text-mint-700">查看</button>
    </div>
  `;
}

function openHelp() {
  openModal(`
    <div class="absolute inset-0 bg-white slide-up overflow-y-auto">
      <header class="flex items-center gap-2 px-3 py-3 border-b border-ink-300/30">
        <button data-close class="w-8 h-8 flex items-center justify-center"><i class="ri-arrow-left-line text-xl"></i></button>
        <h3 class="text-sm font-semibold">帮助中心</h3>
      </header>
      <div class="p-4 space-y-3 text-sm">
        ${[
          { q:'如何发布一件闲置？', a:'进入「发布」Tab，上传最多 3 张照片，填写标题、分类、想换的物品即可。' },
          { q:'怎么和对方联系？', a:'在广场点击「想要」按钮即可发起对话，建议说明自己可交换的物品。' },
          { q:'交换安全指南？', a:'请仅在同城当面交接，确认物品状态后再完成；不要透露转账等敏感信息。' },
          { q:'为什么没有价格？', a:'换换定位「以物换物」，一期不涉及任何交易与支付。' },
          { q:'会话能保留多久？', a:'为节省空间，会话记录仅保留 30 天。' },
        ].map(f => `
          <details class="rounded-xl bg-cream-100 p-3">
            <summary class="font-medium cursor-pointer flex items-center justify-between">
              <span>${f.q}</span>
              <i class="ri-arrow-down-s-line text-ink-500"></i>
            </summary>
            <div class="text-xs text-ink-500 mt-2 leading-relaxed">${f.a}</div>
          </details>
        `).join('')}
      </div>
    </div>
  `);
}

function openFeedback() {
  openModal(`
    <div class="absolute inset-0 bg-white slide-up flex flex-col">
      <header class="flex items-center gap-2 px-3 py-3 border-b border-ink-300/30">
        <button data-close class="w-8 h-8 flex items-center justify-center"><i class="ri-arrow-left-line text-xl"></i></button>
        <h3 class="text-sm font-semibold">反馈与建议</h3>
      </header>
      <div class="flex-1 p-4">
        <textarea id="fb-text" rows="6" maxlength="200" class="field resize-none" placeholder="写下你的建议（200字内，不支持附件）…"></textarea>
        <div class="text-right text-[11px] text-ink-400 mt-1" id="fb-count">0/200</div>
      </div>
      <div class="p-3">
        <button id="fb-submit" class="btn-primary w-full">提交反馈</button>
      </div>
    </div>
  `);
  const t = document.getElementById('fb-text');
  t.addEventListener('input', () => { document.getElementById('fb-count').textContent = `${t.value.length}/200`; });
  document.getElementById('fb-submit').addEventListener('click', () => {
    if (!t.value.trim()) { toast('写点什么再提交吧～'); return; }
    closeModal();
    toast('已收到你的反馈，谢谢！');
  });
}

function openAbout() {
  openModal(`
    <div class="absolute inset-0 bg-white slide-up flex flex-col">
      <header class="flex items-center gap-2 px-3 py-3 border-b border-ink-300/30">
        <button data-close class="w-8 h-8 flex items-center justify-center"><i class="ri-arrow-left-line text-xl"></i></button>
        <h3 class="text-sm font-semibold">关于换换</h3>
      </header>
      <div class="flex-1 flex flex-col items-center justify-center text-center p-6">
        <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-mint-400 to-mint-600 flex items-center justify-center shadow-soft mb-3">
          <i class="ri-loop-left-line text-white text-3xl"></i>
        </div>
        <div class="text-base font-semibold">换换 Exchange</div>
        <div class="text-xs text-ink-500 mt-1">Version 1.0.0</div>
        <p class="text-xs text-ink-500 mt-4 leading-relaxed max-w-[260px]">
          这是一个轻量化的个人闲置物品交换平台。<br/>
          我们相信，流动的旧物，比闲置更有温度。
        </p>
      </div>
    </div>
  `);
}

function openEditProfile() {
  openModal(`
    <div class="absolute inset-0 bg-white slide-up flex flex-col">
      <header class="flex items-center gap-2 px-3 py-3 border-b border-ink-300/30">
        <button data-close class="w-8 h-8 flex items-center justify-center"><i class="ri-close-line text-xl"></i></button>
        <h3 class="text-sm font-semibold flex-1">编辑资料</h3>
        <button id="save-profile" class="text-sm text-mint-600 font-medium px-2">保存</button>
      </header>
      <div class="p-4 space-y-4">
        <div>
          <label class="text-xs text-ink-500">昵称</label>
          <input id="p-name" class="field mt-1.5" value="${esc(ME.name)}" maxlength="10" />
        </div>
        <div>
          <label class="text-xs text-ink-500">个人简介</label>
          <textarea id="p-bio" class="field mt-1.5 resize-none" rows="3" maxlength="50">${esc(ME.bio)}</textarea>
          <div class="text-right text-[11px] text-ink-400 mt-0.5">最多 50 字</div>
        </div>
      </div>
    </div>
  `);
  document.getElementById('save-profile').addEventListener('click', () => {
    ME.name = document.getElementById('p-name').value.trim() || ME.name;
    ME.bio = document.getElementById('p-bio').value.trim() || ME.bio;
    closeModal();
    toast('资料已更新');
    renderMe(document.getElementById('app'));
  });
}
